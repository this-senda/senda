# ignore build but let ./build/config.yml
/build/*
!/build/config.yml

# Go
*.test
*.out

# Frontend
/frontend/node_modules/
/frontend/dist/
/frontend/tests/visual/__screenshots__/
# one-off verify/repro scripts — keep shoot/check-rail/mock-backend
/frontend/tests/visual/verify-*.mjs
/frontend/tests/visual/repro-*.mjs

# Wails generated bindings (regenerated from Go)
/frontend/wailsjs/
/frontend/bindings/

# Playwright
/test-results/
/frontend/test-results/
/frontend/playwright-report/

# OS / editor
.DS_Store
*.swp

bin/

# Generated large example collection tree (regenerate with: task gen:examples:large).
# Only the packed examples-collection/large.senda.zip is committed.
/examples-collection/large/

# scratch/temp files (Claude work area)
tmp/
.security/
.senda/
history.jsonl
# Local Claude Code settings (never ship to the public repo)
.claude/
# Root-level built binary (anchored so it doesn't match the cmd/senda source
# directory). `go build .` and `go build ./cmd/senda` both emit ./senda.
/senda

# Local screenshot-capture browser cache (Chrome-for-Testing)
/.cache/
